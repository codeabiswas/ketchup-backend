{
  "title": "GCP \u2014 vLLM Cloud Run",
  "uid": "gcp-vllm-cloudrun",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "stackdriver",
        "label": "Cloud Monitoring datasource",
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "stackdriver",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "${datasource}"
          },
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "qwen-tool-25",
            "metricType": "run.googleapis.com/request_count",
            "filters": [
              "resource.label.service_name",
              "=",
              "ketchup-vllm"
            ],
            "groupBys": [],
            "aliasBy": "requests",
            "alignmentPeriod": "cloud-monitoring-auto",
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_RATE",
            "metricKind": "DELTA",
            "valueType": "INT64",
            "editorMode": "visual"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "title": "5xx Error Rate",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "stackdriver",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "${datasource}"
          },
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "qwen-tool-25",
            "metricType": "run.googleapis.com/request_count",
            "filters": [
              "resource.label.service_name",
              "=",
              "ketchup-vllm",
              "AND",
              "metric.label.response_code_class",
              "=",
              "5xx"
            ],
            "groupBys": [],
            "aliasBy": "5xx errors",
            "alignmentPeriod": "cloud-monitoring-auto",
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_RATE",
            "metricKind": "DELTA",
            "valueType": "INT64",
            "editorMode": "visual"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Instances",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "stackdriver",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "stackdriver",
            "uid": "${datasource}"
          },
          "queryType": "metrics",
          "metricQuery": {
            "projectName": "qwen-tool-25",
            "metricType": "run.googleapis.com/container/instance_count",
            "filters": [
              "resource.label.service_name",
              "=",
              "ketchup-vllm"
            ],
            "groupBys": [],
            "aliasBy": "instances",
            "alignmentPeriod": "cloud-monitoring-auto",
            "crossSeriesReducer": "REDUCE_SUM",
            "perSeriesAligner": "ALIGN_MEAN",
            "metricKind": "GAUGE",
            "valueType": "INT64",
            "editorMode": "visual"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "P99 Request Latency",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "stackdriver",
        "uid": "${datasource}"
      },
      "targets": [
