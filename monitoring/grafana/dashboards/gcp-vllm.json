              "ketchup-vllm"
            ],
            "groupBys": [],
            "aliasBy": "p99",
            "alignmentPeriod": "cloud-monitoring-auto",
            "crossSeriesReducer": "REDUCE_PERCENTILE_99",
            "perSeriesAligner": "ALIGN_DELTA",
            "metricKind": "DELTA",
            "valueType": "DISTRIBUTION",
            "editorMode": "visual"
          }
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 30000
              }
            ]
          }
        }
      }
    },
